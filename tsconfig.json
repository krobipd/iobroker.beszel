// Root tsconfig to set the settings and power editor support for all TS files
{
	"extends": "@tsconfig/node22/tsconfig.json",
	"compilerOptions": {
		// do not compile anything, this file is just to configure type checking
		// the compilation is configured in tsconfig.build.json
		"noEmit": true,

		// check JS files, but do not compile them => tsconfig.build.json
		"allowJs": true,
		"checkJs": true,

		"noEmitOnError": true,
		"outDir": "./build/",
		"removeComments": false,

		// This is necessary for the automatic typing of the adapter config
		"resolveJsonModule": true,

		// v0.5.0 (P6): TS 6 zieht keine @types/* mehr automatisch — explizit
		// vitest/globals (für `describe`/`it`/`expect`-Globals in *.test.ts)
		// plus node (für `node:http`/`node:url`/`Buffer`-Globals).
		"types": ["vitest/globals", "node"],

		"sourceMap": true,
		"inlineSourceMap": false
	},
	"include": [
		"src/**/*.ts",
		"test/**/*.ts"
	],
	"exclude": [
		"build/**",
		"node_modules/**",
		"widgets/**"
	]
}
