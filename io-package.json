		"authors": [
			"krobi <krobi@power-dreams.com>"
		],
		"licenseInformation": {
			"license": "MIT",
			"type": "free"
		},
		"platform": "Javascript/Node.js",
		"icon": "beszel.svg",
		"extIcon": "https://raw.githubusercontent.com/krobipd/iobroker.beszel/main/admin/beszel.svg",
		"readme": "https://github.com/krobipd/iobroker.beszel/blob/main/README.md",
		"enabled": true,
		"tier": 3,
		"loglevel": "info",
		"mode": "daemon",
		"type": "monitoring",
		"compact": true,
		"connectionType": "local",
		"dataSource": "poll",
		"adminUI": {
			"config": "json"
		},
		"supportedMessages": {
			"stopInstance": true,
			"checkConnection": true
		},
		"dependencies": [
			{
				"js-controller": ">=7.0.0"
			}
		],
		"globalDependencies": [
			{
				"admin": ">=7.6.20"
			}
		],
		"instanceObjects": [
			{
				"_id": "info",
				"type": "channel",
				"common": {
					"name": "Information"
				},
				"native": {}
			},
			{
				"_id": "info.connection",
				"type": "state",
				"common": {
					"name": "Connection status",
					"type": "boolean",
					"role": "indicator.connected",
					"read": true,
					"write": false,
					"def": false
				},
				"native": {}
			}
		]
	},
	"encryptedNative": [
		"password"
	],
	"protectedNative": [
		"password"
	],
	"native": {
		"url": "",
		"username": "",
		"password": "",
		"pollInterval": 60,
		"metrics_uptime": true,
		"metrics_agentVersion": false,
		"metrics_services": false,
		"metrics_cpu": true,
		"metrics_loadAvg": true,
		"metrics_cpuBreakdown": false,
		"metrics_memory": true,
		"metrics_memoryDetails": false,
		"metrics_swap": false,
		"metrics_disk": true,
		"metrics_diskSpeed": true,
		"metrics_extraFs": false,
		"metrics_network": true,
		"metrics_temperature": true,
		"metrics_temperatureDetails": false,
		"metrics_gpu": false,
		"metrics_containers": false,
		"metrics_battery": false
	}
}
