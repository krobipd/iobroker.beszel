{
    "type": "tabs",
    "i18n": true,
    "items": {
        "tab_connection": {
            "type": "panel",
            "label": "tab_connection",
            "items": {
                "url": {
                    "type": "text",
                    "label": "label_url",
                    "help": "help_url",
                    "placeholder": "http://192.168.1.100:8090",
                    "xs": 12,
                    "sm": 12,
                    "md": 8,
                    "lg": 8,
                    "xl": 8
                },
                "pollInterval": {
                    "type": "number",
                    "label": "label_pollInterval",
                    "help": "help_pollInterval",
                    "min": 10,
                    "max": 300,
                    "default": 60,
                    "xs": 12,
                    "sm": 12,
                    "md": 4,
                    "lg": 4,
                    "xl": 4
                },
                "username": {
                    "type": "text",
                    "label": "label_username",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "password": {
                    "type": "password",
                    "label": "label_password",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "checkConnection": {
                    "type": "sendTo",
                    "command": "checkConnection",
                    "jsonData": "{\"url\": \"${data.url}\", \"username\": \"${data.username}\", \"password\": \"${data.password}\"}",
                    "label": "btn_checkConnection",
                    "result": {
                        "okText": "msg_connectionOk",
                        "errorText": "msg_connectionFailed"
                    },
                    "xs": 12,
                    "sm": 12,
                    "md": 4,
                    "lg": 4,
                    "xl": 4
                }
            }
        },
